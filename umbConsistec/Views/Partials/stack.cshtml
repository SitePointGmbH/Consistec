@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models
@using System.Text.Json
@using Umbraco.Cms.Core.Models.Blocks;

<div class="stacking-wrapper" id="third-section">
    <section class="p-section sec-intro" id="p-sec-1">
        <div class="container">
            <div class="row g-5 mb-lg-4">
                <div class="col-lg-12">
                    <img class="position-absolute left-40px z-index-minus-1 animation-rotation d-none d-lg-flex"
                        src="assets/img/stacking_layer_images/image1.png" alt="" style="top: -150px;">
                    <div>
                        @Model.Value("stackTitle")
                    </div>
                </div>
            </div>
            <div class="row g-5 align-items-start mb-5">
                <div class="col-lg-5">
                    <div class="industry-grid-mockup">
                        @Model.Value("leftSideContent")
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="ps-lg-5">
                        <div>
                            @Model.Value("rightSideContent")
                        </div>
                    </div>
                </div>

                

                <div class="row justify-content-center text-center gx-lg-5">
                    @{
                        var dataSources = Model.Value<BlockListModel>("dataSources");
                        if (dataSources != null)
                        {
                            int index = 0;
                            foreach (var block in dataSources)
                            { 
                                var content = block.Content;
                                var heading = content.Value<string>("title");
                                var image = content.Value<IPublishedContent>("image");
                                    
                                var hasPurpleBox = index < 2;

                                <div class="col-lg-4 col-md-6">
                                    <div class="d-flex flex-column align-items-center">
                                        <h2 class="flow-heading mb-4">@Html.Raw(heading?.Replace("\n", "<br>"))</h2>
                                        
                                        <div class="@(hasPurpleBox ? "purple-box" : "") d-flex align-items-center justify-content-center rounded-3" style="height: 150px;">
                                            @if (image != null)
                                            {
                                                <img src="@image.Url()" alt="@heading" class="@(!hasPurpleBox ? "rounded-3" : "")">
                                            }
                                        </div>
                                        <div class="arrow"></div>
                                    </div>
                                </div>
                                index++;
                            }
                        }
                    }
                </div>
        </div>
    </section>

    <section class="p-section sec-event" id="p-sec-2">
        <div class="container">
            <div class="row justify-content-center text-center gy-5 gx-xl-5 ">
                @{
                    var securityAnalyticsLayers = Model.Value<BlockListModel>("securityAnalyticsLayers");
                    if (securityAnalyticsLayers != null)
                    {
                        foreach (var block in securityAnalyticsLayers)
                        {
                            var content = block.Content;
                            var title = content.Value<string>("title");
                            var description = content.Value<string>("description");
                            var image = content.Value<IPublishedContent>("image");

                            <div class="col-xl col-lg-3 col-md-6">
                                <div class="analysis-item">
                                    <div class="analysis-title">
                                        @Html.Raw(title?.Replace("\n", "<br>"))
                                    </div>
                                    <div class="analysis-box">
                                        @if (image != null)
                                        {
                                            <img src="@image.Url()" alt="@title" class="ai-icon">
                                        }
                                        else if (!string.IsNullOrWhiteSpace(description))
                                        {
                                            <div class="analysis-text">
                                                @Html.Raw(description.Replace("\n", "<br>"))
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
            <div class="big-arrow-wrap">
                <div class="big-arrow"></div>
            </div>
        </div>

    </section>

    <section class="p-section sec-analysis" id="p-sec-3">

        <div class="container text-center">
            <div class="row justify-content-center text-center gy-5 gx-xl-5">
                @{
                    var keyBenefits = Model.Value<IEnumerable<string>>("keyBenefits");
                    if (keyBenefits != null && keyBenefits.Any())
                    {
                        foreach (var benefit in keyBenefits)
                        {
                            <div class="col-xl col-lg-4 col-md-6 d-flex">
                                <div class="benefit-card">
                                    <div class="benefit-box">
                                        <div class="benefit-text">
                                            @benefit
                                        </div>
                                    </div>
                                    <div class="check">
                                        <img src="/assets/img/check-icon.svg" alt="Check">
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </section>
</div>
